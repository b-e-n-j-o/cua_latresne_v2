# Identifiants smoke tests — NE PAS COMMITTER
# Copier ce fichier vers .env.test.local à la racine du backend :
#   cp .env.test.example .env.test.local
#
# .env.test.local est gitignoré. Le .env principal reste pour l'app (Supabase, DB…).

AUTH_TEST_EMAIL=c.collantier@gmail.com
AUTH_TEST_PASSWORD=Kerelia123+

# 1 pour activer test_superadmin_when_expected
AUTH_TEST_EXPECT_SUPERADMIN=0

# Slug pour GET /pipelines/by_user (ex. argeles, latresne)
AUTH_TEST_COMMUNE_SLUG=argeles

# Optionnel — surcharge des URLs (sinon localhost / api.kerelia.fr via --prod)
# AUTH_TEST_API_BASE=http://127.0.0.1:8000
# AUTH_TEST_PROD_API_BASE=https://api.kerelia.fr
